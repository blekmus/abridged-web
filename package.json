{
  "name": "abridged-web",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "vite",
    "check": "biome check . && tsc --noEmit",
    "fix": "biome check --write --verbose .",
    "build": "bun run fix && bun run check && vite build"
  },
  "dependencies": {
    "preact": "^10.26.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
