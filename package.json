{
  "name": "abridged-web",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "bun frontend/scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "build": "bun run check && bun frontend/scripts/build.mjs"
  },
  "dependencies": {
    "preact": "^10.26.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.7.2",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3"
  }
}
